{
    "builds": [{
        "src": "ConsumerCompass/wsgi.py",
        "use": "@ardnt/vercel-python-wsgi",
        "config": { "maxLambdaSize": "15mb", "runtime": "python3.9","buildCommand":"build_files.sh"}
    },
    {
        "src":"build_files.sh",
        "use":"@vercel/static-build",
        "config": {"distDir":"staticfiles_build"}
    }],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "ConsumerCompass/wsgi.py"
        },
        {
            "src:": "/static/(.*)",
            "dest": "/static/$1"
        }
    ]
}